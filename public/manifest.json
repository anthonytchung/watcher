{
  "manifest_version": 3,
  "name": "Watcher for YouTube",
  "description": "Detects YouTube watch page metadata and opens matching titles in Stremio Web.",
  "version": "0.1.0",
  "permissions": [],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://youtube.com/watch*", "https://www.youtube.com/watch*", "https://m.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

{
  "name": "watcher-youtube-extension",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.background.config.ts",
    "dev": "npm run build && concurrently -k \"vite build --watch --emptyOutDir=false\" \"vite build --config vite.background.config.ts --watch\"",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^24.0.13",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
